#!/bin/sh

VERSION="2.3.3"

case "$1" in
    configure)
        if dkms status -m agnocast -v "$VERSION" 2>/dev/null | grep -q agnocast; then
            echo "agnocast DKMS version $VERSION is already registered. Skipping."
        else
            if ! dkms add -m agnocast -v "$VERSION"; then
                echo "WARNING: DKMS add failed. The agnocast kernel module is not available."
                exit 0
            fi

            if ! dkms build -m agnocast -v "$VERSION"; then
                echo "WARNING: DKMS build failed for kernel $(uname -r). The agnocast kernel module is not available."
                echo "Rolling back DKMS registration."
                dkms remove -m agnocast -v "$VERSION" --all 2>/dev/null || true
                echo "If you need the kernel module, install linux-headers-$(uname -r) and run:"
                echo "  sudo dkms add -m agnocast -v $VERSION && sudo dkms build -m agnocast -v $VERSION && sudo dkms install -m agnocast -v $VERSION"
                exit 0
            fi
        fi

        if ! dkms install -m agnocast -v "$VERSION"; then
            echo "WARNING: DKMS install failed for kernel $(uname -r). The agnocast kernel module was built but not installed."
            echo "You can retry manually with:"
            echo "  sudo dkms install -m agnocast -v $VERSION"
            exit 0
        fi

        # Remove stale agnocast DKMS registrations only after the new version is
        # successfully installed, so a build/install failure never leaves the
        # machine without a working module.
        for old_ver in $(dkms status -m agnocast 2>/dev/null | sed -n 's/^agnocast[,/] *\([^,]*\),.*/\1/p' | sort -u); do
            if [ "$old_ver" != "$VERSION" ]; then
                echo "Removing stale agnocast DKMS version: $old_ver"
                dkms remove -m agnocast -v "$old_ver" --all || true
            fi
        done
    ;;
esac

#DEBHELPER#

exit 0
